{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.VineetV2/peon-mem",
  "description": "Local-first memory brain for AI coding agents: session capture via hooks, belief consolidation, per-project and global brains, measured token savings.",
  "repository": {
    "url": "https://github.com/VineetV2/peon-mem",
    "source": "github"
  },
  "version": "1.0.2",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "peon-mem",
      "version": "1.0.2",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "PEON_DAEMON_URL",
          "description": "Peon daemon address",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "default": "http://127.0.0.1:3737"
        }
      ]
    }
  ]
}
